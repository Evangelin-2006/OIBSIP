# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/pizza_delivery

# Server Port
PORT=5000

# Email Configuration (for low stock alerts)
# Using Gmail: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Admin Email (where alerts will be sent)
ADMIN_EMAIL=admin@pizzadelivery.com

# JWT Secret
JWT_SECRET=your-secret-key-here

# Razorpay Configuration (if using payment processing)
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
